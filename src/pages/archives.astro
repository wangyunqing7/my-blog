---
import Layout from '../layouts/Layout.astro';
import { getSortedPosts, getSortedPhotos, formatDate } from '../lib/utils';

const posts = await getSortedPosts();
const photos = await getSortedPhotos();

interface ArchiveItem {
  title: string;
  href: string;
  date: Date;
  type: 'post' | 'gallery';
}

const allItems: ArchiveItem[] = [
  ...posts.map((p) => ({ title: p.data.title, href: `/posts/${p.id}`, date: p.data.date, type: 'post' as const })),
  ...photos.map((p) => ({ title: p.data.title, href: `/gallery/${p.id}`, date: p.data.date, type: 'gallery' as const })),
].sort((a, b) => b.date.getTime() - a.date.getTime());

interface MonthGroup { month: string; items: ArchiveItem[]; }
interface YearGroup { year: number; months: MonthGroup[]; }

const monthNames = ['一月', '二月', '三月', '四月', '五月', '六月', '七月', '八月', '九月', '十月', '十一月', '十二月'];

const grouped: YearGroup[] = [];
let currentYear = 0;
let currentMonth = -1;

for (const item of allItems) {
  const year = item.date.getFullYear();
  const month = item.date.getMonth();
  if (year !== currentYear) {
    currentYear = year;
    currentMonth = month;
    grouped.push({ year, months: [{ month: monthNames[month], items: [] }] });
  } else if (month !== currentMonth) {
    currentMonth = month;
    grouped[grouped.length - 1].months.push({ month: monthNames[month], items: [] });
  }
  grouped[grouped.length - 1].months[grouped[grouped.length - 1].months.length - 1].items.push(item);
}
---

<Layout title="归档 - Yunqing's Blog" description="所有文章与作品按时间归档。" active="archives">
  <main>
    <section class="page-header">
      <h1 class="page-title">归档</h1>
      <p class="page-desc">按时间线浏览所有文章与作品</p>
    </section>
    {grouped.map((group) => (
      <section class="year-group">
        <h2 class="year-title">{group.year}</h2>
        {group.months.map((mg) => (
          <div class="month-group">
            <h3 class="month-title">{mg.month}</h3>
            <ul class="archive-list">
              {mg.items.map((item) => (
                <li class="archive-item">
                  <time class="archive-date">{formatDate(item.date)}</time>
                  <span class={`archive-type ${item.type}`}>{item.type === 'gallery' ? '作品' : '文章'}</span>
                  <a href={item.href} class="archive-title">{item.title}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </section>
    ))}
  </main>
</Layout>

<style>
  main { max-width: var(--max-width); margin: 0 auto; padding: 0 1.5rem 5rem; }
  .page-header { padding: 3rem 0 3.5rem; }
  .page-title { font-family: var(--font-serif); font-size: 2rem; font-weight: 500; color: var(--warm-900); letter-spacing: -0.02em; margin-bottom: 0.75rem; }
  .page-desc { font-size: 1.0625rem; color: var(--warm-500); line-height: 1.6; }
  .year-group { margin-bottom: 3rem; }
  .year-title { font-family: var(--font-serif); font-size: 1.5rem; font-weight: 500; color: var(--coral-500); margin-bottom: 1.25rem; letter-spacing: -0.01em; }
  .month-group { margin-bottom: 1.5rem; }
  .month-title { font-size: 1rem; font-weight: 600; color: var(--warm-700); margin-bottom: 0.75rem; padding-left: 0.5rem; border-left: 3px solid var(--coral-300); }
  .archive-list { list-style: none; padding: 0; }
  .archive-item { display: flex; align-items: baseline; gap: 1rem; padding: 0.875rem 0; border-bottom: 1px solid var(--cream-300); }
  .archive-item:last-child { border-bottom: none; }
  .archive-date { font-size: 0.8125rem; color: var(--warm-400); min-width: 120px; flex-shrink: 0; }
  .archive-type {
    font-size: 0.625rem;
    font-weight: 600;
    padding: 0.125rem 0.5rem;
    border-radius: 100px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
  .archive-type.post {
    color: var(--warm-500);
    background: var(--cream-200);
  }
  .archive-type.gallery {
    color: var(--coral-500);
    background: var(--cream-200);
  }
  .archive-title { font-size: 1rem; color: var(--warm-700); transition: color 0.2s ease; }
  .archive-title:hover { color: var(--terracotta); }
  @media (max-width: 768px) {
    main { padding: 0 1.25rem 3rem; }
    .archive-item { flex-wrap: wrap; gap: 0.375rem; }
    .archive-date { min-width: auto; }
  }
</style>

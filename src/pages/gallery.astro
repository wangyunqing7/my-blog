---
import Layout from '../layouts/Layout.astro';
import { getSortedPhotos, formatDate } from '../lib/utils';

const photos = await getSortedPhotos();
---

<Layout title="作品集 - Yunqing's Blog" description="用镜头记录生活的瞬间。" active="gallery">
  <main>
    <section class="page-header">
      <h1 class="page-title">作品集</h1>
      <p class="page-desc">用镜头记录生活的瞬间</p>
    </section>

    <div class="grid">
      {photos.map((photo) => (
        <a href={`/gallery/${photo.id}`} class="card">
          <div class="card-img">
            <img src={photo.data.images[0]} alt={photo.data.title} loading="lazy" />
            {photo.data.images.length > 1 && <span class="card-badge">{photo.data.images.length} 张</span>}
          </div>
          <div class="card-body">
            <h3 class="card-title">{photo.data.title}</h3>
            <div class="card-meta">
              {photo.data.location && <span class="card-location">{photo.data.location}</span>}
              <span class="card-date">{formatDate(photo.data.date)}</span>
            </div>
            {photo.data.tags.length > 0 && (
              <div class="card-tags">
                {photo.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    {photos.length === 0 && (
      <p class="empty-hint">还没有照片，敬请期待。</p>
    )}
  </main>
</Layout>

<style>
  main { max-width: var(--max-width); margin: 0 auto; padding: 0 1.5rem 5rem; }
  .page-header { padding: 3rem 0 3.5rem; }
  .page-title {
    font-family: var(--font-serif);
    font-size: 2rem;
    font-weight: 500;
    color: var(--warm-900);
    letter-spacing: -0.02em;
    margin-bottom: 0.75rem;
  }
  .page-desc { font-size: 1.0625rem; color: var(--warm-500); line-height: 1.6; }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.5rem;
  }

  .card {
    border-radius: 14px;
    overflow: hidden;
    background: var(--cream-100);
    border: 1px solid var(--cream-300);
    transition: transform 0.25s ease, box-shadow 0.25s ease;
    text-decoration: none;
  }
  .card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(45, 42, 38, 0.1);
  }

  .card-img {
    position: relative;
    overflow: hidden;
  }
  .card-img img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .card:hover .card-img img { transform: scale(1.04); }
  .card-badge {
    position: absolute;
    top: 0.625rem;
    right: 0.625rem;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(8px);
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.6875rem;
    font-weight: 500;
    padding: 0.1875rem 0.5rem;
    border-radius: 100px;
  }

  .card-body { padding: 1rem 1.125rem 1.25rem; }
  .card-title {
    font-family: var(--font-serif);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--warm-900);
    margin-bottom: 0.375rem;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.75rem;
    color: var(--warm-400);
    margin-bottom: 0.625rem;
  }
  .card-tags { display: flex; gap: 0.375rem; flex-wrap: wrap; }
  .tag {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--warm-700);
    background: var(--cream-200);
    padding: 0.1875rem 0.5rem;
    border-radius: 100px;
  }

  .empty-hint {
    text-align: center;
    padding: 4rem 0;
    color: var(--warm-400);
    font-size: 0.9375rem;
  }

  @media (max-width: 768px) {
    .grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; }
    main { padding: 0 1.25rem 3rem; }
    .page-header { padding: 2rem 0 2.5rem; }
  }
  @media (max-width: 480px) {
    .grid { grid-template-columns: 1fr; }
    main { padding: 0 1rem 3rem; }
  }
</style>
